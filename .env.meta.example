# ===========================================
# META (FACEBOOK) CONVERSIONS API CONFIGURATION
# ===========================================
# Enterprise-Grade Server-Side Tracking Setup
# 
# SETUP INSTRUCTIONS:
# 1. Go to Facebook Business Settings -> System Users
# 2. Create a new System User (or use existing)
# 3. Generate an Access Token with ads_management permission
# 4. Get your Pixel ID from Events Manager
# 5. Copy this file to .env and fill in your values
#
# IMPORTANT SECURITY NOTES:
# - Never commit your .env file to version control
# - Keep your access token secure
# - Rotate tokens periodically
# ===========================================

# Your Facebook Pixel ID (required)
# This MUST match the Pixel ID used in frontend
META_PIXEL_ID=YOUR_PIXEL_ID_HERE

# Conversions API Access Token (required for CAPI)
# Generate from: Business Settings -> System Users -> Generate Token
# Required permissions: ads_management, ads_read
META_ACCESS_TOKEN=YOUR_ACCESS_TOKEN_HERE

# Test Event Code (optional, for development/testing)
# Find this in Events Manager -> Test Events
# This allows you to test CAPI events without affecting real data
# Remove or leave empty in production
META_TEST_EVENT_CODE=

# ===========================================
# EXISTING CONFIGURATION
# ===========================================
# Add your existing environment variables below

# Frontend URLs for CORS
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT Secret
JWT_SECRET=
